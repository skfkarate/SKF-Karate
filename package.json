{
  "name": "skf-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:ci": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:analyze": "NODE_OPTIONS=--max-old-space-size=4096 next build && node scripts/analyze-next-bundle.mjs --details",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:backend": "eslint app/api/contact/route.ts app/api/leads/route.ts app/api/analytics/track/route.ts app/api/admin/settings/status/route.ts app/api/admin/programs/[id]/template/route.ts app/api/shop/checkout/route.ts app/api/classes/route.ts app/api/events/route.ts app/api/shop/catalog/route.ts app/api/auth/me/route.ts app/api/auth/portal/route.ts app/api/portal/videos/progress/route.ts app/api/webhooks/razorpay/route.ts app/api/health/route.ts src/server app/admin/shop/actions.ts app/admin/shop/products/actions.ts app/_components/contact/contactSubmissionQueue.tsx app/book-trial/trialSubmissionQueue.tsx app/portal/login/page.js app/shop/page.tsx app/shop/[productId]/page.tsx proxy.ts --max-warnings 0 --no-error-on-unmatched-pattern",
    "test:unit": "vitest run",
    "test:events": "vitest run tests/unit/events",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:fix": "eslint . --fix && prettier --write .",
    "type-check": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "audit:assets": "node scripts/audit-static-assets.mjs",
    "audit:assets:ci": "node scripts/audit-static-assets.mjs --ci",
    "analyze:bundle": "node scripts/analyze-next-bundle.mjs --details",
    "check:bundle": "node scripts/analyze-next-bundle.mjs --ci",
    "check:env": "node scripts/check-env-contract.mjs",
    "check:supabase": "node scripts/check-supabase-readiness.mjs",
    "check:lighthouse": "node scripts/check-lighthouse.mjs",
    "cleanup:fee-proofs:dry": "node scripts/cleanup-reviewed-fee-proofs.mjs",
    "cleanup:fee-proofs": "node scripts/cleanup-reviewed-fee-proofs.mjs --apply",
    "migrate:feetrack:dry": "node scripts/migrate-feetrack-google-sheet.mjs",
    "migrate:feetrack:apply": "node scripts/migrate-feetrack-google-sheet.mjs --apply",
    "convert:heic": "node scripts/convert-heic-images.mjs",
    "convert:heic:dry": "node scripts/convert-heic-images.mjs --dry-run",
    "optimize:images": "node scripts/optimize-public-images.mjs",
    "optimize:images:dry": "node scripts/optimize-public-images.mjs --dry-run",
    "audit:media-manifest": "node scripts/audit-media-manifest.mjs",
    "audit:media-manifest:ci": "node scripts/audit-media-manifest.mjs --ci"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.4.0",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.96.2",
    "@types/html2canvas": "^0.5.35",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.35.2",
    "googleapis": "^171.4.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.13",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.10",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "resend": "^6.9.4",
    "tailwindcss": "^4.2.1",
    "web-vitals": "^3.5.2",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "heic-convert": "^2.1.0",
    "lighthouse": "^13.3.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "minimatch@9.0.9": {
      "brace-expansion": "2.0.3"
    },
    "next": {
      "postcss": "8.5.12"
    },
    "next-auth": {
      "uuid": "14.0.0"
    },
    "resend": {
      "svix": "1.92.2"
    }
  }
}
