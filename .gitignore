# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Build output
/.next/
.next/
/out/
out/
/build
/.data

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build-log*.txt
tsc-errors.log

# Env files (keep only .env.example)
.env
.env.local
.env.production
.env*.local
!.env.example

# Misc junk
.DS_Store
*.pem
scratch.js
structure.txt
tsconfig.tsbuildinfo
*.tsbuildinfo

# Junk files (must never be committed)
cookies.txt
*.dump.txt
*_dump.txt
contents.txt
scratch/
test_sheets_fetch.ts
get_ids.js

# Auto-generated sitemaps (generated at build time)
public/sitemap*.xml
public/Samay Raina - STILL ALIVE (Full Special).webm

# Camera/source media originals
*.HEIC
*.MOV
*.mov

# Unused oversized news originals
public/news/*.png

# Local test artifacts
test-results/

# Vercel
.vercel

# TypeScript
next-env.d.ts
