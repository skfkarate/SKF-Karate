# Runtime
# Required in production. Use "development", "test", or "production".
NODE_ENV=development

# Application URLs
# Required: canonical public application URL.
NEXT_PUBLIC_APP_URL=https://www.skfkarate.org
# Required: public site URL used by metadata and social previews.
NEXT_PUBLIC_SITE_URL=https://www.skfkarate.org
# Optional: CDN origin for media assets.
NEXT_PUBLIC_MEDIA_CDN_ORIGIN=

# Feature Flags
# Required: shop/payments must remain false until Razorpay is live.
SHOP_ENABLED=false
PAYMENTS_ENABLED=false
# Required: certificate feature is WIP and should stay false until launched.
CERTIFICATES_ENABLED=false
# Required: points system is enabled unless explicitly disabled.
POINTS_ENABLED=true
# Required: public technique library is opt-in.
PUBLIC_TECHNIQUE_VIDEOS_ENABLED=false
# Required: manual or gateway.
TREASURY_COLLECTION_MODE=manual

# Authentication
# Required: signs athlete portal JWT cookies. Minimum 32 characters.
JWT_SECRET=
# Required for FeeTrack staff fallback login until all staff users are database-backed.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Required for instructor login if instructor role is enabled.
INSTRUCTOR_USERNAME=
INSTRUCTOR_PASSWORD=

# Supabase
# Public by design: exposed to the browser and protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret: server-only service role key. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Redis Rate Limiting (Upstash)
# Optional locally, recommended/required for production abuse protection.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay Payments
# Optional until payments are enabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend Email
# Optional, required for certificate/admin email notifications.
RESEND_API_KEY=
ADMIN_EMAIL=admin@skfkarate.com

# Telegram Notifications
# Optional. Existing/default bot is used for contact and lead alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional. Dedicated bot/channel for public lead and admission alerts.
TELEGRAM_LEADS_BOT_TOKEN=
TELEGRAM_LEADS_CHAT_ID=
# Optional. Used for SKF Payments / FeeTrack operations alerts.
TELEGRAM_FEES_BOT_TOKEN=
TELEGRAM_FEES_CHAT_ID=
# Optional. Used for shop orders and camp/order intake alerts.
TELEGRAM_ORDERS_BOT_TOKEN=
TELEGRAM_ORDERS_CHAT_ID=
# Optional. Reserved for system/ops failure alerts.
TELEGRAM_SYSTEM_BOT_TOKEN=
TELEGRAM_SYSTEM_CHAT_ID=
# Optional. Used for birthday and event reminder digests.
TELEGRAM_REMINDERS_BOT_TOKEN=
TELEGRAM_REMINDERS_CHAT_ID=

# Google integrations
# Required for admissions photo Drive storage; also used by legacy Sheets flows.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Optional legacy/single-root fallback for admissions. Prefer the dedicated photo folder ID below.
ADMISSION_DRIVE_ROOT_FOLDER_ID=
# Required for admissions. Google Drive folder where parent-uploaded student photos are stored before review.
ADMISSION_PHOTO_DRIVE_FOLDER_ID=
# Optional legacy data integration.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_ID_SUMMER_CAMP=
GOOGLE_SHEET_ID_SHOP=
# Optional migration source for the legacy standalone FeeTrack Google Sheet.
FEETRACK_GOOGLE_SHEET_ID=
FEETRACK_MIGRATION_YEAR=2026

# FeeTrack Integration
# Required when the standalone SKF-FeeTrack deployment calls this app as its backend.
FEETRACK_API_KEY=
# Optional, required for FeeTrack browser push notifications while the app is closed.
# Generate with: npx web-push generate-vapid-keys
FEETRACK_WEB_PUSH_PUBLIC_KEY=
FEETRACK_WEB_PUSH_PRIVATE_KEY=
FEETRACK_WEB_PUSH_SUBJECT=mailto:admin@skfkarate.com

# Analytics, SEO, Cron, and Monitoring
# Optional. Google Search Console verification token from Search Console.
GOOGLE_SITE_VERIFICATION=
# Optional. Browser-safe Google Analytics measurement ID.
NEXT_PUBLIC_GA_ID=
# Optional. Shared secret used by scheduled cron endpoints.
CRON_SECRET=
# Required in production for error tracking. Get from Sentry project Settings > Client Keys (DSN).
SENTRY_DSN=
# Required in production for CI source-map uploads. Get from Sentry Settings > Auth Tokens.
SENTRY_AUTH_TOKEN=
# Required in production for source-map uploads. Your Sentry organization slug.
SENTRY_ORG=skf-karate
# Required in production for source-map uploads. Your Sentry SKF-Karate project slug.
SENTRY_PROJECT=skf-website
# Optional. Overrides the Sentry environment label; usually production, preview, or development.
SENTRY_ENVIRONMENT=development

# Local Data Fallbacks
# Optional: directory used by local JSON fallback repositories.
SKF_DATA_DIR=.data
