# Runtime
# Required in production. Use "development", "test", or "production".
NODE_ENV=development

# Application URLs
# Required: canonical public application URL.
NEXT_PUBLIC_APP_URL=https://skfkarate.org
# Required: public site URL used by metadata and social previews.
NEXT_PUBLIC_SITE_URL=https://skfkarate.org
# Optional: CDN origin for media assets.
NEXT_PUBLIC_MEDIA_CDN_ORIGIN=

# Feature Flags
# Required: shop/payments must remain false until Razorpay is live.
SHOP_ENABLED=false
PAYMENTS_ENABLED=false
# Required: certificate feature is WIP and should stay false until launched.
CERTIFICATES_ENABLED=false
# Required: points system is enabled unless explicitly disabled.
POINTS_ENABLED=true
# Required: public technique library is opt-in.
PUBLIC_TECHNIQUE_VIDEOS_ENABLED=false
# Required: manual or gateway.
TREASURY_COLLECTION_MODE=manual

# Authentication
# Required: signs athlete portal JWT cookies. Minimum 32 characters.
JWT_SECRET=
# Required for admin NextAuth in production. Minimum 32 characters.
NEXTAUTH_SECRET=
# Optional: set when the deployed auth callback URL differs from NEXT_PUBLIC_APP_URL.
NEXTAUTH_URL=
# Required until admin users are fully database-backed.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Required for instructor login if instructor role is enabled.
INSTRUCTOR_USERNAME=
INSTRUCTOR_PASSWORD=

# Supabase
# Public by design: exposed to the browser and protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret: server-only service role key. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Redis Rate Limiting (Upstash)
# Optional locally, recommended/required for production abuse protection.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay Payments
# Optional until payments are enabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend Email
# Optional, required for certificate/admin email notifications.
RESEND_API_KEY=
ADMIN_EMAIL=admin@skfkarate.com

# Telegram Notifications
# Optional. Existing/default bot is used for contact and lead alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional. Used for SKF Payments / FeeTrack operations alerts.
TELEGRAM_FEES_BOT_TOKEN=
TELEGRAM_FEES_CHAT_ID=
# Optional. Used for shop orders and camp/order intake alerts.
TELEGRAM_ORDERS_BOT_TOKEN=
TELEGRAM_ORDERS_CHAT_ID=
# Optional. Reserved for system/ops failure alerts.
TELEGRAM_SYSTEM_BOT_TOKEN=
TELEGRAM_SYSTEM_CHAT_ID=
# Optional. Used for birthday and event reminder digests.
TELEGRAM_REMINDERS_BOT_TOKEN=
TELEGRAM_REMINDERS_CHAT_ID=

# Google Sheets
# Optional legacy data integration. These are the only supported Google key names.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_ID_SUMMER_CAMP=
GOOGLE_SHEET_ID_SHOP=
# Optional migration source for the legacy standalone FeeTrack Google Sheet.
FEETRACK_GOOGLE_SHEET_ID=
FEETRACK_MIGRATION_YEAR=2026

# FeeTrack Integration
# Required when the standalone SKF-FeeTrack deployment calls this app as its backend.
FEETRACK_API_KEY=

# Analytics, SEO, Cron, and Monitoring
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_ID=
CRON_SECRET=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Local Data Fallbacks
# Optional: directory used by local JSON fallback repositories.
SKF_DATA_DIR=.data
